// Firestore security rules (example)
// Only allow create/update/delete for admin users on admin collections
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isKnownAdminEmail() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email in [
          'jlekanjarteh@rmu.edu.gh'
        ];
    }

    function isAdmin() {
      return request.auth != null
        && (
          request.auth.token.admin == true
          || request.auth.token.role == 'admin'
          || isKnownAdminEmail()
          || (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'Admin', 'ADMIN']
          )
        );
    }

    function isSelf(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAllowedNonAdminRole(role) {
      return role in ['student', 'faculty', 'guest', 'staff'];
    }

    match /buildings/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /locations/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /notifications/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /events/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /dining/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /rules/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /amenities/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /reports/{docId} {
      allow read: if isAdmin();
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    match /favourite/{docId} {
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    match /users/{userId} {
      allow read: if isSelf(userId) || isAdmin();

      // A user may create their own profile doc, but cannot assign themselves admin.
      allow create: if isSelf(userId)
                    && (!('role' in request.resource.data) || isAllowedNonAdminRole(request.resource.data.role))
                    || isAdmin();

      // A user may update their own profile, but cannot change role.
      // Admins may update any user.
      allow update: if isAdmin()
                    || (isSelf(userId)
                        && (request.resource.data.role == resource.data.role));

      // Prevent users from deleting their own profile doc; admins only.
      allow delete: if isAdmin();
    }
  }
}